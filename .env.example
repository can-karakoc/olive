# Google Earth Engine (for Sentinel-2 access)
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=./gee-service-account.json

# Database (Neon PostgreSQL with PostGIS)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/oliveintel?sslmode=require

# Storage (Cloudflare R2 or AWS S3)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=oliveintel-cogs
AWS_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com  # For R2; remove for AWS S3

# Copernicus Climate Data Store (for ERA5-Land weather data)
CDS_API_KEY=your_cds_api_key
CDS_UID=your_cds_uid

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Processing Configuration
MAX_CLOUD_PROBABILITY=20
COMPOSITE_DAYS=10
N_WORKERS=4

# Logging
LOG_LEVEL=INFO
